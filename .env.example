# Kora runs fully local by default — no env vars are required for `npm run dev`.
# The SQLite database lives at packages/db/dev.db and is auto-discovered.

# Override the database location (optional)
# DATABASE_URL="file:/absolute/path/to/dev.db"

# Secrets for session cookies + QR check-in tokens.
# Default to "dev-secret" in development — set real values in production.
# AUTH_SECRET=change_this_to_a_random_64_char_string
# QR_HMAC_SECRET=change_this_to_a_random_64_char_string

# App URLs (optional)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
