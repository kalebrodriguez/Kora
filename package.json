{
  "name": "kora",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:push": "turbo run db:push --filter=@kora/db",
    "db:studio": "turbo run db:studio --filter=@kora/db",
    "db:seed": "turbo run db:seed --filter=@kora/db",
    "db:reset": "turbo run db:reset --filter=@kora/db",
    "setup": "npm run db:reset",
    "setup:demo": "npm run db:push && npm run db:seed"
  },
  "devDependencies": {
    "turbo": "^2.9.16",
    "typescript": "^5.0.0"
  },
  "packageManager": "npm@10.0.0"
}
